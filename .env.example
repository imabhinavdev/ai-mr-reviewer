PORT=3000
NODE_ENV=development

# Public URL of your server (no trailing slash). Used in startup logs so you know the webhook URL.
# Examples: https://your-domain.com  or  http://localhost:3000
BASE_URL=http://localhost:3000

# AI: set one (or both; Gemini takes precedence)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Git: set tokens for the providers you use (GitHub and/or GitLab)
GITHUB_TOKEN=your_github_personal_access_token
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_URL=https://gitlab.com

# Webhook security (recommended in production)
# GitHub: set in repo Settings → Webhooks → Secret; app validates X-Hub-Signature-256
GITHUB_WEBHOOK_SECRET=
# GitLab: set in project Settings → Webhooks → Secret token; app validates X-Gitlab-Token
GITLAB_WEBHOOK_TOKEN=
# Metrics: required; use a long random value. /metrics requires Authorization: Bearer <METRICS_TOKEN>
METRICS_TOKEN=replace_with_a_long_random_token

# Redis (job queue). Optional; default: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# Concurrency for the review worker. Optional; default: 1
# REVIEW_WORKER_CONCURRENCY=1

# PostgreSQL (Docker Compose). Used by the postgres service and to build DATABASE_URL for the app.
# When using Docker Compose, the app's DATABASE_URL is set from these; you do not need to set DATABASE_URL in .env.
POSTGRES_PASSWORD=
POSTGRES_USER=nirik
POSTGRES_DB=nirik

# Dashboard and analytics (optional). When set, review events are stored and the dashboard is available.
# PostgreSQL connection URL. Required for analytics and dashboard when running outside Docker.
# When using Docker Compose, DATABASE_URL is set automatically from POSTGRES_* above.
# DATABASE_URL=postgresql://user:password@localhost:5432/nirik

# Admin credentials for dashboard login. Required for auth when using the dashboard.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your_secure_password

# JWT secret for dashboard tokens. Min 32 characters. Required for auth.
# JWT_SECRET=replace_with_at_least_32_character_secret

# Self-hosted GitLab: set GITLAB_URL to your instance (e.g. https://git.mycompany.com)

# Nginx proxy + Let's Encrypt (optional). When set, app is reached via nginx-proxy with automatic HTTPS.
# Set VIRTUAL_HOST and LETSENCRYPT_* when using docker-compose with nginx-proxy and acme-companion.
# VIRTUAL_HOST=domain.com
# VIRTUAL_PORT=3000
# LETSENCRYPT_HOST=domain.com
# LETSENCRYPT_EMAIL=your@email.com

# Optional
LOG_LEVEL=info
# Production: optional file path for duplicated file logs (stdout logging is always enabled)
# LOG_FILE_PATH=logs/app.log
